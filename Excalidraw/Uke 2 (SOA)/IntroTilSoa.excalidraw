      "text": "Frontend bryr seg kun om:\n- GET /Tasks\n- POST /Tasks\n- DELETE /Tasks/{id}\n(Frontend bryr seg kun om resultatet)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Frontend bryr seg kun om:\n- GET /Tasks\n- POST /Tasks\n- DELETE /Tasks/{id}\n(Frontend bryr seg kun om resultatet)",
      "autoResize": true,
      "lineHeight": 1.25
